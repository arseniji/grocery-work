meta {
  name: refresh
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/v1/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refreshToken": "{{refresh_token}}"
  }
}

script:after-response {
  if (res.status === 200) {
    bru.setVar("access_token", res.body.accessToken);
    bru.setVar("refresh_token", res.body.refreshToken);
  }
}
