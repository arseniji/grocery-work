meta {
  name: login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "login": "admin",
    "password": "Admin123"
  }
}

script:after-response {
  if (res.status === 200) {
    bru.setVar("access_token", res.body.accessToken);
    bru.setVar("refresh_token", res.body.refreshToken);
  }
}
